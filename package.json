{
  "name": "data-mesh",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "npx concurrently -n API,WEB -c cyan,magenta \"npm run api:dev\" \"npm run web:dev\"",
    "build": "npm run api:build && npm run web:build",
    "health": "npx concurrently -n PG,REDIS,API,WEB -c green,yellow,cyan,magenta \"docker inspect --format='{{.State.Health.Status}}' datamesh-postgres\" \"docker inspect --format='{{.State.Health.Status}}' datamesh-redis\" \"curl -sf http://localhost:3000/health || echo 'API not reachable'\" \"curl -sf http://localhost:4200 || echo 'Web not reachable'\"",
    "api:dev": "nx serve api",
    "api:build": "nx build api",
    "api:test": "nx test api",
    "api:test:watch": "nx test api --watch",
    "api:lint": "nx lint api",
    "web:dev": "nx dev web",
    "web:build": "nx build web",
    "web:test": "nx test web",
    "web:lint": "nx lint web",
    "ingestion:install": "pip install -e \"./apps/ingestion[dev]\"",
    "ingestion:run": "python -m ingestion",
    "ingestion:test": "cd apps/ingestion && pytest",
    "ingestion:lint": "cd apps/ingestion && ruff check src/",
    "ingestion:typecheck": "cd apps/ingestion && mypy src/",
    "format": "nx format:write",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "docker:up": "docker-compose up -d",
    "docker:up:infra": "docker-compose up -d postgres redis",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@hookform/resolvers": "3.9.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
