# ─── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/datamesh_dev?schema=public"

# ─── Redis (Upstash) ──────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRY="15m"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"
JWT_REFRESH_EXPIRY="7d"

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── EU Data Sources ──────────────────────────────────────────
EEA_BASE_URL="https://discomap.eea.europa.eu/map/fme/public"
EUROSTAT_BASE_URL="https://ec.europa.eu/eurostat/api/dissemination"

# ─── Next.js Public ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="http://localhost:4200"
